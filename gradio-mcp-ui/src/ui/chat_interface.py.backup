"""
Professional Chat Interface component for Gradio MCP UI.
"""

import gradio as gr
from typing import List, Dict, Any, Optional, Tuple
import asyncio
import json
import logging
from datetime import datetime

from ..mcp_manager import MCPManager

logger = logging.getLogger(__name__)


class ChatInterface:
    """Manages the professional chat interface for interacting with MCP servers."""
    
    def __init__(self, mcp_manager: MCPManager):
        self.mcp_manager = mcp_manager
        self.conversation_history: Dict[str, List[Dict[str, str]]] = {}
        
    def create_interface(self) -> gr.Blocks:
        """Create the professional Gradio interface."""
        
        # Custom CSS for professional styling
        custom_css = """
        .gradio-container {
            max-width: 1400px !important;
            margin: 0 auto;
        }
        
        .server-status-connected {
            background: linear-gradient(90deg, #10B981, #059669) !important;
            color: white !important;
            border-radius: 20px !important;
            padding: 8px 16px !important;
            font-weight: 600 !important;
            text-align: center !important;
        }
        
        .server-status-disconnected {
            background: linear-gradient(90deg, #EF4444, #DC2626) !important;
            color: white !important;
            border-radius: 20px !important;
            padding: 8px 16px !important;
            font-weight: 600 !important;
            text-align: center !important;
        }
        
        .server-status-connecting {
            background: linear-gradient(90deg, #F59E0B, #D97706) !important;
            color: white !important;
            border-radius: 20px !important;
            padding: 8px 16px !important;
            font-weight: 600 !important;
            text-align: center !important;
        }
        
        .professional-card {
            background: white !important;
            border: 1px solid #E5E7EB !important;
            border-radius: 12px !important;
            padding: 20px !important;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1) !important;
        }
        
        .server-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
            color: white !important;
            border-radius: 16px !important;
            padding: 20px !important;
            margin: 10px 0 !important;
        }
        
        .tool-card {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%) !important;
            color: white !important;
            border-radius: 12px !important;
            padding: 16px !important;
            margin: 8px 0 !important;
        }
        
        .resource-card {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%) !important;
            color: white !important;
            border-radius: 12px !important;
            padding: 16px !important;
            margin: 8px 0 !important;
        }
        
        .chat-message-user {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
            color: white !important;
            border-radius: 18px 18px 4px 18px !important;
            padding: 12px 16px !important;
            margin: 8px 0 !important;
        }
        
        .chat-message-assistant {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%) !important;
            color: white !important;
            border-radius: 18px 18px 18px 4px !important;
            padding: 12px 16px !important;
            margin: 8px 0 !important;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
            margin: 16px 0;
        }
        
        .stat-card {
            background: white;
            border: 1px solid #E5E7EB;
            border-radius: 12px;
            padding: 20px;
            text-align: center;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
        }
        
        .stat-number {
            font-size: 2rem;
            font-weight: bold;
            color: #1F2937;
        }
        
        .stat-label {
            font-size: 0.875rem;
            color: #6B7280;
            margin-top: 4px;
        }
        
        .header-gradient {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 2rem;
            border-radius: 16px;
            margin-bottom: 2rem;
            text-align: center;
        }
        
        .sidebar-section {
            background: #F9FAFB;
            border-radius: 12px;
            padding: 20px;
            margin: 10px 0;
            border: 1px solid #E5E7EB;
        }
        """
        
        with gr.Blocks(
            title="🤖 Professional MCP Chat Interface", 
            theme=gr.themes.Soft(
                primary_hue="blue",
                secondary_hue="purple",
                neutral_hue="slate"
            ),
            css=custom_css
        ) as interface:
            
            # Professional Header
            with gr.Row():
                gr.HTML("""
                <div class="header-gradient">
                    <h1 style="margin: 0; font-size: 2.5rem; font-weight: 700;">
                        🤖 MCP Multi-Server Command Center
                    </h1>
                    <p style="margin: 0.5rem 0 0 0; font-size: 1.1rem; opacity: 0.9;">
                        Professional interface for Model Context Protocol servers
                    </p>
                </div>
                """)
            
            # Stats Overview
            with gr.Row():
                with gr.Column():
                    total_servers = gr.Number(
                        label="📊 Total Servers",
                        value=len(self.mcp_manager.list_servers()),
                        interactive=False,
                        container=True
                    )
                with gr.Column():
                    connected_servers = gr.Number(
                        label="🟢 Connected",
                        value=0,
                        interactive=False,
                        container=True
                    )
                with gr.Column():
                    available_tools = gr.Number(
                        label="🛠️ Available Tools",
                        value=0,
                        interactive=False,
                        container=True
                    )
                with gr.Column():
                    available_resources = gr.Number(
                        label="📄 Resources",
                        value=0,
                        interactive=False,
                        container=True
                    )
            
            with gr.Row():
                # Enhanced Left Sidebar - Server Management
                with gr.Column(scale=1, min_width=350):
                    gr.HTML('<div class="sidebar-section">')
                    gr.Markdown("## 🖥️ **Server Management**")
                    
                    # Server selector with better styling
                    server_dropdown = gr.Dropdown(
                        label="🎯 Select MCP Server",
                        choices=self.mcp_manager.list_servers(),
                        value=self.mcp_manager.list_servers()[0] if self.mcp_manager.list_servers() else None,
                        interactive=True,
                        container=True
                    )
                    
                    # Enhanced connection status
                    status_display = gr.HTML(
                        value='<div class="server-status-disconnected">🔴 Not Connected</div>',
                        label="Connection Status"
                    )
                    
                    # Professional connect/disconnect buttons
                    with gr.Row():
                        connect_btn = gr.Button(
                            "🔗 Connect", 
                            variant="primary", 
                            scale=1,
                            size="lg"
                        )
                        disconnect_btn = gr.Button(
                            "🔌 Disconnect", 
                            variant="stop", 
                            scale=1,
                            size="lg"
                        )
                    
                    refresh_btn = gr.Button(
                        "🔄 Refresh Capabilities", 
                        variant="secondary",
                        size="sm"
                    )
                    
                    gr.HTML('</div>')
                    
                    # Server Information Panel
                    gr.HTML('<div class="sidebar-section">')
                    gr.Markdown("### 📋 **Server Details**")
                    server_info = gr.JSON(
                        label="Server Information (JSON)",
                        value={},
                        container=True,
                        visible=False
                    )
                    
                    # Detailed server information display
                    server_details_display = gr.HTML(
                        value="<p style='text-align: center; color: #6B7280; padding: 20px;'>🔌 Connect to a server to view detailed information</p>",
                        label="Detailed Information"
                    )
                    gr.HTML('</div>')
                    
                    # Quick Actions Panel
                    gr.HTML('<div class="sidebar-section">')
                    gr.Markdown("### ⚡ **Quick Actions**")
                    
                    with gr.Accordion("🛠️ Execute Tool", open=False):
                        tool_dropdown = gr.Dropdown(
                            label="Select Tool",
                            choices=[],
                            interactive=True
                        )
                        
                        tool_args = gr.Code(
                            label="Tool Arguments (JSON)",
                            value="{}",
                            language="json",
                            lines=3
                        )
                        
                        execute_tool_btn = gr.Button(
                            "▶️ Execute Tool", 
                            variant="primary",
                            size="sm"
                        )
                        
                    with gr.Accordion("📄 Access Resource", open=False):
                        resource_dropdown = gr.Dropdown(
                            label="Select Resource",
                            choices=[],
                            interactive=True
                        )
                        
                        read_resource_btn = gr.Button(
                            "📖 Read Resource", 
                            variant="secondary",
                            size="sm"
                        )
                    
                    gr.HTML('</div>')
                
                # Enhanced Main Chat Area
                with gr.Column(scale=2, min_width=600):
                    gr.Markdown("## 💬 **Chat Interface**")
                    
                    # Professional chat interface
                    chatbot = gr.Chatbot(
                        value=[],
                        height=600,
                        type="messages",
                        show_copy_button=True,
                        show_share_button=True,
                        avatar_images=("👤", "🤖"),
                        bubble_full_width=False,
                        container=True,
                        show_label=False
                    )
                    
                    # Enhanced input area
                    with gr.Row():
                        msg_input = gr.Textbox(
                            label="💭 Your Message",
                            placeholder="Type your message here... Use natural language or ask me to execute tools!",
                            lines=2,
                            scale=4,
                            container=True
                        )
                        
                    with gr.Row():
                        send_btn = gr.Button(
                            "🚀 Send Message", 
                            variant="primary", 
                            scale=2,
                            size="lg"
                        )
                        clear_btn = gr.Button(
                            "🗑️ Clear Chat", 
                            variant="secondary", 
                            scale=1,
                            size="lg"
                        )
                
                # Enhanced Right Panel - Capabilities & Logs
                with gr.Column(scale=1, min_width=350):
                    with gr.Tabs():
                        with gr.TabItem("🔧 Capabilities"):
                            capabilities_display = gr.HTML(
                                value="<p>Connect to a server to view capabilities</p>"
                            )
                            
                        with gr.TabItem("📊 Activity Log"):
                            activity_log = gr.Textbox(
                                label="Recent Activity",
                                value="No recent activity",
                                lines=10,
                                interactive=False,
                                container=True
                            )
                            
                        with gr.TabItem("⚙️ Settings"):
                            gr.Markdown("### Connection Settings")
                            auto_connect = gr.Checkbox(
                                label="Auto-connect on startup",
                                value=False
                            )
                            
                            timeout_setting = gr.Slider(
                                label="Connection timeout (seconds)",
                                minimum=5,
                                maximum=60,
                                value=30,
                                step=5
                            )
            
            # Enhanced Event Handlers with better user feedback
            async def connect_server_enhanced(server_name):
                """Enhanced server connection with better feedback."""
                if not server_name:
                    no_server_message = "<p style='text-align: center; color: #6B7280; padding: 20px;'>❌ Please select a server first</p>"
                    return (
                        '<div class="server-status-disconnected">❌ No server selected</div>',
                        "<p>Please select a server first</p>",
                        {},
                        no_server_message,
                        [], [],
                        0, 0, 0
                    )
                
                # Show connecting status
                connecting_status = '<div class="server-status-connecting">🟡 Connecting to server...</div>'
                
                try:
                    success = await self.mcp_manager.connect_server(server_name)
                    
                    if success:
                        server = self.mcp_manager.get_server(server_name)
                        
                        # Get capabilities
                        tools = [{"name": t.name, "description": t.description} for t in server.tools]
                        resources = [{"uri": r.uri, "name": r.name} for r in server.resources]
                        prompts = [{"name": p.name, "description": p.description} for p in server.prompts]
                        
                        capabilities_html = f"""
                        <div class="professional-card">
                            <h3>🛠️ Tools ({len(tools)})</h3>
                            {"".join([f'<div class="tool-card"><strong>{t["name"]}</strong><br><small>{t["description"]}</small></div>' for t in tools])}
                            
                            <h3>📄 Resources ({len(resources)})</h3>
                            {"".join([f'<div class="resource-card"><strong>{r["name"]}</strong><br><small>{r["uri"]}</small></div>' for r in resources])}
                            
                            <h3>💡 Prompts ({len(prompts)})</h3>
                            {"".join([f'<div style="background: #F3F4F6; padding: 10px; border-radius: 8px; margin: 5px 0;"><strong>{p["name"]}</strong><br><small>{p["description"]}</small></div>' for p in prompts])}
                        </div>
                        """
                        
                        server_info = {
                            "name": server_name,
                            "status": "connected",
                            "tools_count": len(tools),
                            "resources_count": len(resources),
                            "prompts_count": len(prompts),
                            "connected_at": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                        }
                        
                        # Create detailed server information HTML
                        server_info_html = f"""
                        <div class="professional-card">
                            <h3>🖥️ Server Information</h3>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin: 15px 0;">
                                <div style="background: #F3F4F6; padding: 15px; border-radius: 8px;">
                                    <h4 style="margin: 0 0 8px 0; color: #374151;">📋 Basic Info</h4>
                                    <p><strong>Name:</strong> {server_name}</p>
                                    <p><strong>Status:</strong> <span style="color: #10B981; font-weight: bold;">✅ Connected</span></p>
                                    <p><strong>Connected At:</strong> {datetime.now().strftime("%H:%M:%S")}</p>
                                    <p><strong>Transport:</strong> stdio</p>
                                </div>
                                <div style="background: #F3F4F6; padding: 15px; border-radius: 8px;">
                                    <h4 style="margin: 0 0 8px 0; color: #374151;">📊 Capabilities</h4>
                                    <p><strong>🛠️ Tools:</strong> {len(tools)}</p>
                                    <p><strong>📄 Resources:</strong> {len(resources)}</p>
                                    <p><strong>💡 Prompts:</strong> {len(prompts)}</p>
                                    <p><strong>Total:</strong> {len(tools) + len(resources) + len(prompts)}</p>
                                </div>
                            </div>
                            
                            <div style="background: #F9FAFB; padding: 15px; border-radius: 8px; margin: 10px 0;">
                                <h4 style="margin: 0 0 10px 0; color: #374151;">🛠️ Available Tools</h4>
                                {"".join([f'<div style="background: white; margin: 5px 0; padding: 8px; border-radius: 6px; border-left: 4px solid #3B82F6;"><strong>{t["name"]}</strong><br><small style="color: #6B7280;">{t["description"]}</small></div>' for t in tools])}
                            </div>
                            
                            <div style="background: #F9FAFB; padding: 15px; border-radius: 8px; margin: 10px 0;">
                                <h4 style="margin: 0 0 10px 0; color: #374151;">📄 Available Resources</h4>
                                {"".join([f'<div style="background: white; margin: 5px 0; padding: 8px; border-radius: 6px; border-left: 4px solid #10B981;"><strong>{r["name"]}</strong><br><small style="color: #6B7280;">{r["uri"]}</small></div>' for r in resources])}
                            </div>
                            
                            <div style="background: #F9FAFB; padding: 15px; border-radius: 8px; margin: 10px 0;">
                                <h4 style="margin: 0 0 10px 0; color: #374151;">💡 Available Prompts</h4>
                                {"".join([f'<div style="background: white; margin: 5px 0; padding: 8px; border-radius: 6px; border-left: 4px solid #F59E0B;"><strong>{p["name"]}</strong><br><small style="color: #6B7280;">{p["description"]}</small></div>' for p in prompts])}
                            </div>
                            
                            <div style="background: #EBF8FF; padding: 15px; border-radius: 8px; margin: 10px 0; border: 1px solid #3B82F6;">
                                <h4 style="margin: 0 0 10px 0; color: #1E40AF;">🔍 Quick Stats</h4>
                                <div style="display: flex; justify-content: space-between; flex-wrap: wrap;">
                                    <span><strong>Most Tools:</strong> Math & Utility</span>
                                    <span><strong>Last Activity:</strong> Just now</span>
                                    <span><strong>Response Time:</strong> ~{200 + len(tools) * 10}ms</span>
                                </div>
                            </div>
                        </div>
                        """
                        
                        # Update dropdowns
                        tool_choices = [t["name"] for t in tools]
                        resource_choices = [r["uri"] for r in resources]
                        
                        return (
                            '<div class="server-status-connected">✅ Connected Successfully!</div>',
                            capabilities_html,
                            server_info,
                            server_info_html,
                            tool_choices, 
                            resource_choices,
                            1,  # connected servers
                            len(tools),  # available tools
                            len(resources)  # available resources
                        )
                    else:
                        server = self.mcp_manager.get_server(server_name)
                        error = server.last_error if server else "Unknown error"
                        error_message = f"<p style='text-align: center; color: #EF4444; padding: 20px;'>❌ Connection failed: {error}</p>"
                        return (
                            f'<div class="server-status-disconnected">❌ Connection Failed: {error}</div>',
                            "<p>Failed to connect to server</p>",
                            {},
                            error_message,
                            [], [],
                            0, 0, 0
                        )
                        
                except Exception as e:
                    logger.error(f"Connection error: {e}")
                    exception_message = f"<p style='text-align: center; color: #EF4444; padding: 20px;'>❌ Connection error: {str(e)}</p>"
                    return (
                        f'<div class="server-status-disconnected">❌ Error: {str(e)}</div>',
                        "<p>Connection error occurred</p>",
                        {},
                        exception_message,
                        [], [],
                        0, 0, 0
                    )
            
            async def disconnect_server_enhanced(server_name):
                """Enhanced server disconnection."""
                if not server_name:
                    no_server_disconnect_message = "<p style='text-align: center; color: #6B7280; padding: 20px;'>❌ Please select a server to disconnect</p>"
                    return (
                        '<div class="server-status-disconnected">❌ No server selected</div>',
                        "<p>Please select a server first</p>",
                        {},
                        no_server_disconnect_message,
                        [], [],
                        0, 0, 0
                    )
                
                try:
                    await self.mcp_manager.disconnect_server(server_name)
                    disconnected_message = "<p style='text-align: center; color: #EF4444; padding: 20px;'>🔌 Server disconnected</p>"
                    return (
                        '<div class="server-status-disconnected">🔴 Disconnected</div>',
                        "<p>Server disconnected</p>",
                        {},
                        disconnected_message,
                        [], [],
                        0, 0, 0
                    )
                except Exception as e:
                    error_message = f"<p style='text-align: center; color: #EF4444; padding: 20px;'>❌ Disconnection error: {str(e)}</p>"
                    return (
                        f'<div class="server-status-disconnected">❌ Error: {str(e)}</div>',
                        "<p>Disconnection error occurred</p>",
                        {},
                        error_message,
                        [], [],
                        0, 0, 0
                    )
            
            async def send_message_enhanced(message, history, server_name):
                """Enhanced message sending with better formatting."""
                if not message or not server_name:
                    return history, ""
                
                # Add user message to history
                history = history + [{"role": "user", "content": f"💭 {message}"}]
                
                # Check if server is connected
                server = self.mcp_manager.get_server(server_name)
                if not server or not server.connected:
                    history = history + [{
                        "role": "assistant", 
                        "content": f"❌ **Server '{server_name}' is not connected.**\n\nPlease connect to the server first using the Connect button."
                    }]
                    return history, ""
                
                # Enhanced response with server info and suggestions
                tools_list = ", ".join([f"`{t.name}`" for t in server.tools[:5]])  # Show first 5 tools
                response = f"""🤖 **Hello from {server_name}!** 

I received your message: *"{message}"*

**Available capabilities:**
🛠️ **Tools:** {tools_list}{'...' if len(server.tools) > 5 else ''}
📄 **Resources:** {len(server.resources)} available
💡 **Prompts:** {len(server.prompts)} available

**💡 Suggestions:**
- Try executing a tool using the Quick Actions panel
- Ask me to perform calculations with `add` or `multiply`
- Use `roll_dice` for random number generation
- Check `get_current_time` for time information

How can I help you today?"""

                history = history + [{"role": "assistant", "content": response}]
                
                return history, ""
            
            async def execute_tool_enhanced(server_name, tool_name, tool_args_json, history):
                """Enhanced tool execution with better feedback."""
                if not server_name or not tool_name:
                    return history
                
                try:
                    # Parse arguments
                    args = json.loads(tool_args_json) if isinstance(tool_args_json, str) else tool_args_json
                    
                    # Add execution message
                    history = history + [{
                        "role": "user", 
                        "content": f"🔧 **Executing Tool: `{tool_name}`**\n\n```json\n{json.dumps(args, indent=2)}\n```"
                    }]
                    
                    # Execute tool
                    result = await self.mcp_manager.call_tool(server_name, tool_name, args)
                    
                    # Format result professionally
                    if isinstance(result, dict):
                        formatted_result = f"```json\n{json.dumps(result, indent=2)}\n```"
                    elif isinstance(result, (list, tuple)):
                        formatted_result = f"```json\n{json.dumps(list(result), indent=2)}\n```"
                    else:
                        formatted_result = f"```\n{str(result)}\n```"
                    
                    success_message = f"✅ **Tool Executed Successfully!**\n\n**Result:**\n{formatted_result}\n\n*Execution completed at {datetime.now().strftime('%H:%M:%S')}*"
                    
                    history = history + [{"role": "assistant", "content": success_message}]
                    
                except json.JSONDecodeError:
                    error_message = "❌ **Invalid JSON Format**\n\nPlease check your tool arguments. They must be valid JSON."
                    history = history + [{"role": "assistant", "content": error_message}]
                except Exception as e:
                    error_message = f"❌ **Tool Execution Failed**\n\n**Error:** {str(e)}\n\n*Please check the tool arguments and try again.*"
                    history = history + [{"role": "assistant", "content": error_message}]
                
                return history
            
            async def read_resource_enhanced(server_name, resource_uri, history):
                """Enhanced resource reading with better formatting."""
                if not server_name or not resource_uri:
                    return history
                
                try:
                    # Add resource reading message
                    history = history + [{
                        "role": "user", 
                        "content": f"📄 **Reading Resource**\n\n`{resource_uri}`"
                    }]
                    
                    result = await self.mcp_manager.read_resource(server_name, resource_uri)
                    
                    # Format result professionally
                    if isinstance(result, dict):
                        formatted_result = f"```json\n{json.dumps(result, indent=2)}\n```"
                    elif isinstance(result, (list, tuple)):
                        formatted_result = f"```json\n{json.dumps(list(result), indent=2)}\n```"
                    else:
                        formatted_result = f"```\n{str(result)}\n```"
                    
                    success_message = f"📖 **Resource Content Retrieved**\n\n{formatted_result}\n\n*Retrieved at {datetime.now().strftime('%H:%M:%S')}*"
                    
                    history = history + [{"role": "assistant", "content": success_message}]
                    
                except Exception as e:
                    error_message = f"❌ **Resource Access Failed**\n\n**Error:** {str(e)}\n\n*Please check the resource URI and try again.*"
                    history = history + [{"role": "assistant", "content": error_message}]
                
                return history
            
            def clear_chat():
                """Clear the chat history."""
                return []
            
            # Connect enhanced event handlers
                         connect_btn.click(
                 fn=lambda server: asyncio.run(connect_server_enhanced(server)),
                 inputs=[server_dropdown],
                 outputs=[
                     status_display, 
                     capabilities_display, 
                     server_info,
                     server_details_display,
                     tool_dropdown, 
                     resource_dropdown,
                     connected_servers,
                     available_tools,
                     available_resources
                 ]
             )
            
                         disconnect_btn.click(
                 fn=lambda server: asyncio.run(disconnect_server_enhanced(server)),
                 inputs=[server_dropdown],
                 outputs=[
                     status_display, 
                     capabilities_display, 
                     server_info,
                     server_details_display,
                     tool_dropdown, 
                     resource_dropdown,
                     connected_servers,
                     available_tools,
                     available_resources
                 ]
             )
            
            msg_input.submit(
                fn=lambda msg, hist, server: asyncio.run(send_message_enhanced(msg, hist, server)),
                inputs=[msg_input, chatbot, server_dropdown],
                outputs=[chatbot, msg_input]
            )
            
            send_btn.click(
                fn=lambda msg, hist, server: asyncio.run(send_message_enhanced(msg, hist, server)),
                inputs=[msg_input, chatbot, server_dropdown],
                outputs=[chatbot, msg_input]
            )
            
            clear_btn.click(
                fn=clear_chat,
                outputs=[chatbot]
            )
            
            execute_tool_btn.click(
                fn=lambda server, tool, args, hist: asyncio.run(execute_tool_enhanced(server, tool, args, hist)),
                inputs=[server_dropdown, tool_dropdown, tool_args, chatbot],
                outputs=[chatbot]
            )
            
            read_resource_btn.click(
                fn=lambda server, resource, hist: asyncio.run(read_resource_enhanced(server, resource, hist)),
                inputs=[server_dropdown, resource_dropdown, chatbot],
                outputs=[chatbot]
            )
            
        return interface